# ── Audio ─────────────────────────────────────────────────────────────────────
# Virtual audio device used for recording.
# Verify the exact name by running:
#   ffmpeg -f avfoundation -list_devices true -i "" 2>&1 | grep -i black
BLACKHOLE_DEVICE=BlackHole 2ch

# Safari Meet only: name of the Multi-Output Device you created in Audio MIDI Setup
# (BlackHole 2ch + your speakers combined). Zoom and Chrome don't use this.
MULTI_OUTPUT_NAME=Recorder Output

# ── Output ────────────────────────────────────────────────────────────────────
# Where to save recordings, transcripts, and JSON files
OUTPUT_DIR=/Users/YOUR_USERNAME/Recordings

# ── Whisper ───────────────────────────────────────────────────────────────────
# Model size options: tiny.en  base.en  small.en  medium.en  large-v3
# medium.en is recommended on M4 Pro — fast and accurate
# large-v3 for maximum accuracy (~3x slower, downloads ~3GB)
WHISPER_MODEL=medium.en

# ── Diarization (speaker labelling) ──────────────────────────────────────────
# Required to identify who said what.
# 1. Accept pyannote terms at: https://huggingface.co/pyannote/speaker-diarization-3.1
# 2. Create a token at:        https://huggingface.co/settings/tokens
# 3. Paste it below:
HF_TOKEN=hf_your_token_here

# Max number of speakers expected in your meetings.
# Pyannote uses this as an upper bound — improves accuracy significantly.
# 4 is a good default for 1-4 person meetings.
NUM_SPEAKERS=4

# ── WebSocket ─────────────────────────────────────────────────────────────────
# Port the daemon listens on for Chrome/Safari extension connections.
# Only change if 8765 is already in use on your machine.
WS_PORT=8765

# ── Zoom Cloud API (optional) ─────────────────────────────────────────────────
# Enriches recordings with participant emails, agenda, and host details.
# Leave blank to skip — recording and transcription work without this.
#
# Setup: marketplace.zoom.us → Build App → Server-to-Server OAuth
# Required scopes: meeting:read:admin  report:read:admin  user:read:admin
#
# ZOOM_ACCOUNT_ID=your_account_id
# ZOOM_CLIENT_ID=your_client_id
# ZOOM_CLIENT_SECRET=your_client_secret
